# GitHub OAuth Application credentials
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# BetterAuth secret for session encryption
# Generate with: openssl rand -base64 32
# For local dev and CI e2e tests this value is fixed to match packages/e2e/utils/sign-cookie.ts.
# Override this in production.
BETTER_AUTH_SECRET=IPTC+aAEkEWhGW4xsgDtt+qaOnK0gpGBelQhKPcchuw=

WEB_URL=http://localhost:3000

# Optional overrides
DB_LOCAL_PATH=.data/db.sqlite
STORAGE_DIR=.data/storage

# For automatic summaries
OPENROUTER_API_KEY=

# For OpenAI-compatible summary backends (preferred when AI_BASE_URL and AI_MODEL are set)
# Examples: Ollama, vLLM, LiteLLM
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# For transactional emails
RESEND_API_KEY=
EMAIL_SENDER=

# GitLab OAuth Application credentials
# Create at: https://gitlab.com/-/user_settings/applications
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_ISSUER=https://gitlab.com

# Waitlist (set to "false" to auto-approve all signups as users)
WAITLIST_ENABLED=true
